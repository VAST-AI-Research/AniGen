                "use_pretrain_branch": true,
                "freeze_pretrain_branch": true,
                "modules_to_freeze": [
                    "blocks",
                    "input_blocks",
                    "input_layer",
                    "out_blocks",
                    "out_layer",
                    "t_embedder"
                ]
            }
        }
    },
    "dataset": {
